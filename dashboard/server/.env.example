AI_OFFICE_ROOT=../../..
DASHBOARD_PORT=4310
SSE_HEARTBEAT_MS=15000
WATCHER_DEBOUNCE_MS=500
# Force an SSE flush within this window even under continuous file writes
# (prevents the watcher from starving live updates during long log bursts).
WATCHER_MAX_WAIT_MS=5000
LOG_TAIL_LINES=500

# Comma-separated CORS allowlist. Set to wherever the dashboard client is served.
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000

# Shared bearer token required for all /api routes except /api/health.
# Leave unset for local-only use (auth disabled, server logs a warning).
# When set, the client prompts for it once and stores it in localStorage.
DASHBOARD_AUTH_TOKEN=
